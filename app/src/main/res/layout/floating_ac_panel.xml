<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_background"
    android:padding="12dp"
    android:elevation="8dp">

    <!-- ① 标题栏 / 拖动区 -->
    <LinearLayout
        android:id="@+id/panel_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F0F0F0">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="❄ 空调控制"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingStart="4dp"/>

        <Switch
            android:id="@+id/switch_ac_power"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_close_panel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="12sp"
            android:padding="0dp"
            android:backgroundTint="#DDDDDD"
            android:textColor="@color/text_secondary"/>
    </LinearLayout>

    <!-- 分割线 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
        android:background="@color/divider"/>

    <!-- ② 温度区：主驾 SeekBar | AUTO | 副驾 SeekBar -->
    <!--    SeekBar rotation=270：往上滑 progress 增大 → 温度降低(32-p)，最小17°C -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal"
        android:layout_marginVertical="4dp">

        <!-- 主驾 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- 主驾标签 16sp -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="主驾"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/ac_blue"
                android:layout_marginBottom="30dp"/>

            <!-- 竖向 SeekBar：height 给足让滑块有空间，rotation=270 -->
            <SeekBar
                android:id="@+id/seekbar_driver_temp"
                android:layout_width="130dp"
                android:layout_height="300dp"
                android:max="15"
                android:progress="7"
                android:rotation="-270"
                android:layout_marginBottom="30dp"/>

            <!-- 温度值显示在滑块下方 -->
            <TextView
                android:id="@+id/tv_driver_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25°C"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ac_blue"/>

        </LinearLayout>

        <!-- 中间 AUTO 按钮 -->
        <LinearLayout
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btn_auto_temp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="AUTO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CCCCCC"
                android:textColor="#333333"/>
        </LinearLayout>

        <!-- 副驾 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="副驾"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/ac_blue"
                android:layout_marginBottom="30dp"/>

            <SeekBar
                android:id="@+id/seekbar_pass_temp"
                android:layout_width="130dp"
                android:layout_height="100dp"
                android:max="15"
                android:progress="7"
                android:rotation="90"
                android:layout_marginBottom="1dp"/>

            <TextView
                android:id="@+id/tv_pass_temp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="25°C"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ac_blue"/>

        </LinearLayout>

    </LinearLayout>

    <!-- 分割线 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginVertical="6dp" android:background="@color/divider"/>

    <!-- ③ 风速 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginVertical="4dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="风速"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>

        <SeekBar
            android:id="@+id/seekbar_fan_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="5"
            android:progress="2"
            android:layout_marginHorizontal="8dp"/>

        <TextView
            android:id="@+id/tv_fan_label"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

    </LinearLayout>

    <!-- ④ 模式 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginVertical="4dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="模式"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>

        <RadioGroup
            android:id="@+id/rg_blow_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginStart="8dp">

            <RadioButton
                android:id="@+id/rb_face"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="吹脸"
                android:textSize="12sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_feet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="吹脚"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

            <RadioButton
                android:id="@+id/rb_defrost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="除霜"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

        </RadioGroup>
    </LinearLayout>

    <!-- 分割线 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginVertical="6dp" android:background="@color/divider"/>

    <!-- ⑤ 内循环 — 全宽切换按钮，无 TextView -->
    <Button
        android:id="@+id/btn_circulation"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="内循环"
        android:textSize="14sp"
        android:backgroundTint="@color/colorPrimary"
        android:textColor="#FFFFFF"/>

</LinearLayout>
